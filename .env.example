# Database
DATABASE_URL=postgresql://jobassistant:password@postgres:5432/job_assistant_db
DATABASE_ECHO=false

# Backend
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Environment
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# AI Models & APIs
OPENAI_API_KEY=sk-your-openai-key
CLAUDE_API_KEY=sk-your-claude-key
GROQ_API_KEY=

# Job Search APIs
LINKEDIN_API_KEY=
INDEED_API_KEY=
GLASSCOOR_API_KEY=
JOBBY_API_KEY=

# Security
ENCRYPTION_KEY=your-encryption-key-for-sensitive-data
AUDIT_LOG_ENABLED=true
SCAM_DETECTION_ENABLED=true
PII_REDACTION_ENABLED=true
PROMPT_INJECTION_DETECTION_ENABLED=true

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# File Upload
MAX_UPLOAD_SIZE_MB=10
ALLOWED_FILE_TYPES=pdf,docx,doc
UPLOAD_DIR=./uploads

# Frontend
REACT_APP_API_URL=http://localhost:8000/api
REACT_APP_WS_URL=ws://localhost:8000/ws
REACT_APP_ENV=development

# Google Cloud
GCP_PROJECT_ID=your-gcp-project
GCP_REGION=us-central1
GCP_BUCKET_NAME=job-assistant-uploads

# Redis (for caching and async tasks)
REDIS_URL=redis://redis:6379/0

# Observability
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
GOOGLE_CLOUD_LOGGING_ENABLED=false

# Email (for notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@jobassistant.com

# Feature Flags
FEATURE_MOCK_JOB_API=true
FEATURE_RESUME_ANALYSIS=true
FEATURE_COVER_LETTER_GENERATION=true
FEATURE_INTERVIEW_PREP=true
FEATURE_SALARY_INSIGHTS=true
FEATURE_CAREER_ROADMAP=true
